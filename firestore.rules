rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { 
      // KIOSK MODE BYPASS: Allow operations if the client UI granted access
      return true;
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidTable(data) {
      return data.id is string
        && data.label is string
        && data.status in ['available', 'reserved', 'occupied', 'paid', 'paying', 'out-of-order'];
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['id', 'name', 'phone', 'partySize', 'addedAt', 'status', 'updatedAt'])
        && data.id is string && data.id.size() <= 64
        && data.name is string && data.name.size() <= 128
        && data.phone is string && data.phone.size() <= 64
        && data.partySize is number
        && data.addedAt is number
        && data.status in ['WAITING', 'NOTIFIED', 'SEATED']
        && (data.get('assignedTable', '') is string && data.get('assignedTable', '').size() <= 64)
        && (data.get('seatedAt', 0) is number)
        && (data.get('syncStatus', '') is string && data.get('syncStatus', '').size() <= 32)
        && (data.get('originalPhone', '') is string && data.get('originalPhone', '').size() <= 64);
    }

    match /tables/{tableId} {
      allow read, write: if true;
    }

    match /restaurants/{restaurantId}/tables_luxury/{tableId} {
      allow read, write: if isSignedIn();
    }
    
    match /test/{docId} {
      allow read, write: if true;
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /customers/{customerId} {
      allow get: if isSignedIn() && isValidId(customerId);
      allow list: if isSignedIn();

      allow create: if isSignedIn() 
        && isValidId(customerId)
        && incoming().keys().hasAll(['id', 'name', 'phone', 'partySize', 'addedAt', 'status', 'updatedAt'])
        && incoming().keys().size() <= 11
        && isValidCustomer(incoming())
        && incoming().updatedAt == request.time;

      allow update: if isSignedIn()
        && isValidId(customerId)
        && isValidCustomer(incoming())
        && incoming().updatedAt == request.time
        && (
           incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) ||
           incoming().diff(existing()).affectedKeys().hasOnly(['assignedTable', 'updatedAt']) ||
           incoming().diff(existing()).affectedKeys().hasOnly(['status', 'assignedTable', 'updatedAt']) ||
           incoming().diff(existing()).affectedKeys().hasOnly(['status', 'seatedAt', 'updatedAt']) ||
           incoming().diff(existing()).affectedKeys().hasOnly(['syncStatus', 'updatedAt'])
        );

      allow delete: if isSignedIn() && isValidId(customerId);
    }
  }
}
