{
  "entities": {
    "Table": {
      "title": "Table",
      "description": "A physical table on the restaurant floor plan.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "x_pos": { "type": "number" },
        "y_pos": { "type": "number" },
        "status": { "type": "string", "enum": ["available", "reserved", "occupied", "paid"] },
        "capacity": { "type": "number" },
        "currentGuest": { "type": "object" }
      },
      "required": ["id", "label", "x_pos", "y_pos", "status"]
    },
    "FloorZone": {
      "title": "FloorZone",
      "description": "A specific zone in a branch containing multiple tables.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "tables": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "tables", "updatedAt"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A guest waiting for a table.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "originalPhone": { "type": "string" },
        "partySize": { "type": "number" },
        "addedAt": { "type": "number" },
        "status": { "type": "string", "enum": ["WAITING", "NOTIFIED", "SEATED"] },
        "assignedTable": { "type": "string" },
        "seatedAt": { "type": "number" },
        "syncStatus": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "phone", "partySize", "addedAt", "status", "updatedAt"]
    }
  },
  "firestore": {
    "/branches/{branchId}/floor_zones/{zoneId}": {
      "schema": { "$ref": "#/entities/FloorZone" },
      "description": "Collection of zones containing table arrays for a given branch."
    },
    "/customers/{customerId}": {
      "schema": { "$ref": "#/entities/Customer" },
      "description": "Waiting list containing current queued customers and their states."
    }
  }
}
